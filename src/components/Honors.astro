---
const { items = [] } = Astro.props;
---

<section id="honors" class="section honors">
  <h2>Honors</h2>
  <ul class="honor-list">
    {
      items.map((item) => (
        <li class="honor-item">
          <span class="honor-title">{item.title}</span>
          <span class="honor-year">{item.year}</span>
        </li>
      ))
    }
  </ul>
</section>
