---
const { items = [] } = Astro.props;
---

<section id="education" class="section card">
  <h2>Education</h2>
  <ul class="edu-list">
    {
      items.map((item) => (
        <li>
          <strong>{item.degree}</strong> - {item.school} ({item.period})
        </li>
      ))
    }
  </ul>
</section>
