---
const { name, subtitle, photo, scholar, github } = Astro.props;
---

<section id="about" class="post about">
  <div class="profile float-right">
    <img class="avatar" src={photo} alt={`Profile photo of ${name}`} />
    <div class="more-info">
      <p>
        <a href={scholar} target="_blank" rel="noreferrer">Google Scholar</a>
      </p>
      <p>
        <a href={github} target="_blank" rel="noreferrer">GitHub</a>
      </p>
    </div>
  </div>
  <header class="post-header">
    <h1 class="post-title">{name}</h1>
    <p class="post-description">{subtitle}</p>
  </header>
  <div class="clearfix"></div>
</section>
