---
const { name, subtitle, photo, summary } = Astro.props;
---

<section id="about" class="post about">
  <div class="profile float-right">
    <img class="avatar" src={photo} alt={`Profile photo of ${name}`} />
    <p class="photo-caption">Pictured in Muscat, Omman</p>
  </div>
  <header class="post-header">
    <h1 class="post-title">{name}</h1>
    <p class="post-description">{subtitle}</p>
    <p class="about-summary">{summary}</p>
  </header>
  <div class="clearfix"></div>
</section>
