---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import About from "../components/About.astro";
import Biography from "../components/Biography.astro";
import Education from "../components/Education.astro";
import Publications from "../components/Publications.astro";
import VisitorCounter from "../components/VisitorCounter.astro";
import profile from "../data/profile.json";
import education from "../data/education.json";
import publications from "../data/publications.json";
import "../styles/global.css";
---

<BaseLayout title={`${profile.name} - Academic Homepage`}>
  <Header
    name={profile.name}
    scholar={profile.scholar}
    github={profile.github}
    email={profile.email}
    linkedin={profile.linkedin}
  />
  <About
    name={profile.name}
    subtitle={profile.subtitle}
    photo={profile.photo}
  />
  <Biography summary={profile.summary} />
  <Education items={education} />
  <Publications papers={publications} />
  <VisitorCounter />
</BaseLayout>
