---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import About from "../components/About.astro";
import Education from "../components/Education.astro";
import Links from "../components/Links.astro";
import Publications from "../components/Publications.astro";
import VisitorCounter from "../components/VisitorCounter.astro";
import profile from "../data/profile.json";
import education from "../data/education.json";
import publications from "../data/publications.json";
import "../styles/global.css";
---

<BaseLayout title={`${profile.name} - Academic Homepage`}>
  <Header name={profile.name} />
  <About photo={profile.photo} summary={profile.summary} />
  <Education items={education} />
  <Publications papers={publications} />
  <Links scholar={profile.scholar} github={profile.github} />
  <VisitorCounter />
</BaseLayout>
